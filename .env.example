# ── Required ──────────────────────────────────────────────────────────────────
# Your EVM wallet address — this is where USDC payments land
WALLET_ADDRESS=0xYourWalletAddressHere

# ── Optional ──────────────────────────────────────────────────────────────────
# "base-sepolia" for testnet (free, no real money)
# "base"         for mainnet (real USDC)
NETWORK=base-sepolia

# Testnet:  https://x402.org/facilitator       (no signup needed)
# Mainnet:  https://api.cdp.coinbase.com/platform/v2/x402  (needs CDP API keys)
FACILITATOR_URL=https://x402.org/facilitator

# Needed only for /api/research endpoint
ANTHROPIC_API_KEY=sk-ant-...

# Server port (default 4021)
PORT=4021
